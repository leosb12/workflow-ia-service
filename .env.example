# Copia este archivo como .env y completa los valores reales.
# No subas el archivo .env real al repositorio.

DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_USER_GUIDE_MODEL=deepseek-chat
DEEPSEEK_MAX_TOKENS=0
DEEPSEEK_TEMPERATURE=0.2
DEEPSEEK_TIMEOUT_SECONDS=0

# En Docker Compose usa el nombre de servicio, no localhost
IA_DEEP_LEARNING_SERVICE_URL=http://ia-deep-learning-service:8010

APP_NAME=ia-service
APP_ENV=production
